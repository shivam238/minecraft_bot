# OpenRouter API Key for AI copilot functionality
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternative AI providers
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROK_API_KEY=your_grok_api_key_here

# Password for server /login or /register commands
PASSWORD=your_minecraft_server_password_here

# Aternos Server Watcher Credentials
ATERNOS_USERNAME=your_aternos_username_here
ATERNOS_PASSWORD=your_aternos_password_here
# Optional: session cookie (bypasses Cloudflare block on login)
ATERNOS_SESSION=your_aternos_session_cookie_here

